
/**
 * Portugal Unido - Firestore Security Rules
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(ownerIdField) {
      return isSignedIn() && resource != null && resource.data[ownerIdField] == request.auth.uid;
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isSignedIn(); 
      allow delete: if isOwner(userId);

      match /notifications/{notificationId} {
        allow get, list: if isOwner(userId);
        allow create: if isSignedIn(); 
        allow update, delete: if isOwner(userId);
      }

      match /profileComments/{commentId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isExistingOwner('authorId');
      }
    }

    match /posts/{postId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn(); 
      allow delete: if isExistingOwner('authorId');

      match /comments/{commentId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isExistingOwner('authorId');
      }

      match /applications/{applicationId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.applicantId == request.auth.uid;
        allow update: if isSignedIn();
        allow delete: if isSignedIn() && (resource.data.applicantId == request.auth.uid || resource.data.postAuthorId == request.auth.uid);
      }
    }

    match /groups/{groupId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isExistingOwner('adminId');
      
      match /messages/{messageId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn();
      }
    }

    match /chats/{chatId} {
      match /messages/{messageId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn();
      }

      match /typing/{userId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
      }
    }
    
    match /ratings/{ratingId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.raterId == request.auth.uid;
    }

    match /denuncias/{reportId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow list: if false; // Only admin via console
    }
  }
}
