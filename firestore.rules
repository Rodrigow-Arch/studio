/**
 * Portugal Unido - Firestore Security Rules
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(ownerIdField) {
      return isSignedIn() && resource != null && resource.data[ownerIdField] == request.auth.uid;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && request.resource.data.points == 0 && request.resource.data.helpsGiven == 0;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      match /notifications/{notificationId} {
        allow get, list: if isOwner(userId);
        allow create: if isSignedIn(); // Permitir que outros enviem notificações de candidatura
        allow update, delete: if isOwner(userId);
      }

      match /profileComments/{commentId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isExistingOwner('authorId');
      }
    }

    match /posts/{postId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn(); // Permitir atualizar contador de candidatos e status
      allow delete: if isExistingOwner('authorId');

      match /comments/{commentId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isExistingOwner('authorId');
      }

      match /applications/{applicationId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.applicantId == request.auth.uid;
        allow update: if isSignedIn();
        allow delete: if isSignedIn() && (resource.data.applicantId == request.auth.uid || resource.data.postAuthorId == request.auth.uid);
      }
    }

    match /chats/{chatId}/messages/{messageId} {
      allow get, list: if isSignedIn() && (request.auth.uid in chatId.split('_'));
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isExistingOwner('authorId');
    }
    
    match /ratings/{ratingId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.raterId == request.auth.uid;
    }
  }
}