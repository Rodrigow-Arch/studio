/**
 * Portugal Unido - Firestore Security Rules
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(ownerIdField) {
      return isSignedIn() && resource != null && resource.data[ownerIdField] == request.auth.uid;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      match /notifications/{notificationId} {
        allow get, list: if isOwner(userId);
        allow create: if isSignedIn(); 
        allow update, delete: if isOwner(userId);
      }

      match /profileComments/{commentId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isExistingOwner('authorId');
      }
    }

    match /posts/{postId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn(); 
      allow delete: if isExistingOwner('authorId');

      match /comments/{commentId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isExistingOwner('authorId');
      }

      match /applications/{applicationId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.applicantId == request.auth.uid;
        allow update: if isSignedIn();
        allow delete: if isSignedIn() && (resource.data.applicantId == request.auth.uid || resource.data.postAuthorId == request.auth.uid);
      }
    }

    match /chats/{chatId} {
      // Regra comum para mensagens e estado de escrita
      function canAccessChat() {
        return isSignedIn() && (
          (request.auth.uid in chatId.split('_')) ||
          (exists(/databases/$(database)/documents/posts/$(chatId)) && (
            get(/databases/$(database)/documents/posts/$(chatId)).data.authorId == request.auth.uid ||
            get(/databases/$(database)/documents/posts/$(chatId)).data.helperId == request.auth.uid
          ))
        );
      }

      match /messages/{messageId} {
        allow get, list: if canAccessChat();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isExistingOwner('authorId');
      }

      match /typing/{userId} {
        allow get, list: if canAccessChat();
        allow create, update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }
    
    match /ratings/{ratingId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.raterId == request.auth.uid;
    }
  }
}